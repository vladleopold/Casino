{
  "collections": [
    {
      "collection": "storefront_pages",
      "purpose": "page-level entries for home, catalog, and live",
      "fields": ["slug", "title", "kicker", "body", "brand_subtitle"]
    },
    {
      "collection": "storefront_route_payloads",
      "purpose": "JSON payloads for route-specific shelves, promos, tiles, and footer signals",
      "fields": ["slug", "payload", "status", "updated_at"]
    },
    {
      "collection": "storefront_navigation_links",
      "purpose": "top navigation",
      "fields": ["page", "label", "href", "position"]
    },
    {
      "collection": "storefront_actions",
      "purpose": "CTA links for hero and sections",
      "fields": ["page", "label", "href", "variant", "position"]
    },
    {
      "collection": "storefront_chips",
      "purpose": "hero chips, console chips, filter pills",
      "fields": ["page", "zone", "label", "active", "position"]
    },
    {
      "collection": "storefront_stat_cards",
      "purpose": "headline metrics and KPI blocks",
      "fields": ["page", "zone", "label", "value", "body", "position"]
    },
    {
      "collection": "storefront_feature_cards",
      "purpose": "generic editorial cards",
      "fields": ["page", "zone", "kicker", "title", "body", "points", "position"]
    },
    {
      "collection": "storefront_showcase_cards",
      "purpose": "catalog and live preview cards",
      "fields": ["page", "zone", "title", "meta", "accent", "position"]
    },
    {
      "collection": "storefront_info_cards",
      "purpose": "console support cards and quick-return cards",
      "fields": ["page", "zone", "label", "value", "body", "position"]
    },
    {
      "collection": "storefront_shelves",
      "purpose": "curated shelf groups",
      "fields": ["page", "title", "slug", "count_label", "position"]
    },
    {
      "collection": "storefront_shelf_items",
      "purpose": "items within shelf groups",
      "fields": ["shelf", "title", "provider", "game_id", "position", "pin", "boost", "hide"]
    },
    {
      "collection": "storefront_activity_items",
      "purpose": "ops feeds and timeline entries",
      "fields": ["page", "zone", "text", "position"]
    }
  ]
}
