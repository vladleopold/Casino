{
  "collections": [
    {
      "collection": "storefront_imported_pages",
      "purpose": "field-based mirrored SlotCity pages with editable hero fields and HTML body",
      "fields": [
        "slug",
        "locale",
        "page_type",
        "shell_route",
        "kicker",
        "source_url",
        "canonical_url",
        "title",
        "heading",
        "description",
        "hero_image",
        "hero_image_url",
        "content_html",
        "extracted_at",
        "status"
      ]
    },
    {
      "collection": "storefront_imported_breadcrumbs",
      "purpose": "repeatable breadcrumb rows for mirrored SlotCity pages",
      "fields": ["slug", "page_slug", "position", "label", "href", "status"]
    },
    {
      "collection": "storefront_banners",
      "purpose": "banner, hero slider, promo slider, and visual promo records with editable Directus images",
      "fields": [
        "slug",
        "route",
        "kind",
        "position",
        "kicker",
        "title",
        "body",
        "href",
        "primary_label",
        "primary_href",
        "secondary_label",
        "secondary_href",
        "accent",
        "color",
        "cta_label",
        "cta_caption",
        "tags",
        "chips",
        "stats",
        "image",
        "image_url",
        "status"
      ]
    },
    {
      "collection": "storefront_pages",
      "purpose": "page-level entries for home, catalog, and live",
      "fields": ["slug", "title", "kicker", "body", "brand_subtitle"]
    },
    {
      "collection": "storefront_sections",
      "purpose": "singleton text sections and editable cards for the storefront",
      "fields": [
        "slug",
        "route",
        "section_key",
        "position",
        "kicker",
        "title",
        "body",
        "note",
        "href",
        "primary_label",
        "primary_href",
        "secondary_label",
        "secondary_href",
        "cta_label",
        "cta_caption",
        "email",
        "phone",
        "address",
        "locale",
        "hours",
        "age",
        "bottom_email",
        "bottom_note",
        "badge",
        "image_alt",
        "search_placeholder",
        "search_shortcut",
        "pill_label",
        "meta",
        "paragraphs",
        "image",
        "image_url",
        "status"
      ]
    },
    {
      "collection": "storefront_section_items",
      "purpose": "repeatable cards and list rows for shelves, FAQ, footer links, pills, and buttons",
      "fields": [
        "slug",
        "route",
        "section_key",
        "item_type",
        "position",
        "group_label",
        "label",
        "title",
        "body",
        "value",
        "href",
        "provider",
        "rank",
        "mark",
        "tone",
        "variant",
        "is_active",
        "caption",
        "width",
        "height",
        "values",
        "image",
        "image_url",
        "status"
      ]
    },
    {
      "collection": "storefront_route_payloads",
      "purpose": "fallback JSON payloads for route-specific content that is not yet decomposed into section collections",
      "fields": ["slug", "payload", "status", "updated_at"]
    },
    {
      "collection": "storefront_navigation_links",
      "purpose": "top navigation",
      "fields": ["page", "label", "href", "position"]
    },
    {
      "collection": "storefront_actions",
      "purpose": "CTA links for hero and sections",
      "fields": ["page", "label", "href", "variant", "position"]
    },
    {
      "collection": "storefront_chips",
      "purpose": "hero chips, console chips, filter pills",
      "fields": ["page", "zone", "label", "active", "position"]
    },
    {
      "collection": "storefront_stat_cards",
      "purpose": "headline metrics and KPI blocks",
      "fields": ["page", "zone", "label", "value", "body", "position"]
    },
    {
      "collection": "storefront_feature_cards",
      "purpose": "generic editorial cards",
      "fields": ["page", "zone", "kicker", "title", "body", "points", "position"]
    },
    {
      "collection": "storefront_showcase_cards",
      "purpose": "catalog and live preview cards",
      "fields": ["page", "zone", "title", "meta", "accent", "position"]
    },
    {
      "collection": "storefront_info_cards",
      "purpose": "console support cards and quick-return cards",
      "fields": ["page", "zone", "label", "value", "body", "position"]
    },
    {
      "collection": "storefront_shelves",
      "purpose": "curated shelf groups",
      "fields": ["page", "title", "slug", "count_label", "position"]
    },
    {
      "collection": "storefront_shelf_items",
      "purpose": "items within shelf groups",
      "fields": ["shelf", "title", "provider", "game_id", "position", "pin", "boost", "hide"]
    },
    {
      "collection": "storefront_activity_items",
      "purpose": "ops feeds and timeline entries",
      "fields": ["page", "zone", "text", "position"]
    }
  ]
}
